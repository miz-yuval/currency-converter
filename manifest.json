{
  "manifest_version": 3,
  "name": "Currency Converter",
  "version": "1.1.0",
  "description": "Select any number on a webpage to instantly convert it between currencies.",

  "permissions": [
    "storage",
    "activeTab"
  ],

  "host_permissions": [
    "https://api.exchangerate-api.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Currency Converter Settings",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
